# .env — Variables d'environnement locales (NE PAS committer)
# Copiez ce fichier en local et remplissez les valeurs réelles.

# Clé API Brixhub (côté serveur)
BRIXHUB_API_KEY=brix_your_real_brixhub_api_key_here

# Si le client (Vite) a besoin d'une clé (à éviter si possible, expose la clé côté client)
VITE_BRIXHUB_API_KEY=brix_nzwl9XbKsYJal8Y0lkdsMQemzu3vjN5hf7PIp4z2tfgZobaG

# Token du bot Telegram (format : <bot_id>:<token>)
TELEGRAM_BOT_TOKEN=8961403780:AAFzXGzq1pqZQIsgplz5F3yvkWmCFbUef3U

# Identifiant du chat Telegram (entier, pour groupes privés souvent -100...)
TELEGRAM_CHAT_ID=7808474075

# Optionnel : base API si vous avez une instance différente (laisser par défaut)
# BRIXHUB_API_BASE=https://api.brixhub.is/api/v1
# DISCORD_API_BASE=https://discord.com/api
